{
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "tui": "fullscreen",
  "theme": "light",
  "editorMode": "vim",
  "agentPushNotifEnabled": true,
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git tag:*)",
      "Bash(git remote:*)",
      "Bash(git blame:*)",
      "Bash(git reflog:*)",
      "Bash(git rev-parse:*)",
      "Bash(git describe:*)",
      "Bash(git shortlog:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-remote:*)",
      "Bash(git show-ref:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git stash push:*)",
      "Bash(git stash list:*)",
      "Bash(git stash show:*)"
    ]
  }
}
